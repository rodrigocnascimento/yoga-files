#!/usr/bin/env zsh
# 🎭 bin/yoga
# @name: yoga-cli
# @desc: CLI Client for Yoga 3.0 - Main Entry Point 🧘‍♂️
# @usage: yoga <command> [args...]
# @author: Yoga 3.0 Lôro Barizon Edition 🦜

set -euo pipefail

# 🏠 Config
YOGA_HOME="${YOGA_HOME:-$HOME/.yoga}"
export YOGA_HOME

# 📦 Source dependencies
source "${YOGA_HOME}/core/utils/ui.sh"
source "${YOGA_HOME}/core/daemon/lifecycle.sh"
source "${YOGA_HOME}/core/daemon/client.sh"

# ═══════════════════════════════════════════════════════════
# 🎯 MAIN
# ═══════════════════════════════════════════════════════════

function main {
    local cmd="${1:-help}"
    [[ $# -gt 0 ]] && shift
    
    # 🎨 Banner nas operações principais
    case "$cmd" in
        daemon|cc|workspace|ai|plugin|state|update|version)
            yoga_banner
            ;;
    esac
    
    # 🎯 Route commands
    case "$cmd" in
        # 👹 Daemon management
        daemon)
            yoga_daemon_command "$@"
            ;;
            
        # 🎯 Command Center
        cc)
            _yoga_cmd_cc "$@"
            ;;
            
        # 🌌 Workspaces
        workspace|ws)
            _yoga_cmd_workspace "$@"
            ;;
            
        # 🚇 Tunnel (cf-tunnels integration)
        tunnel)
            _yoga_cmd_tunnel "$@"
            ;;
            
        # 🤖 AI
        ai|ask)
            _yoga_cmd_ai "$@"
            ;;
            
        # 🔌 Plugins
        plugin|plugins)
            _yoga_cmd_plugin "$@"
            ;;
            
        # 💾 State
        state)
            _yoga_cmd_state "$@"
            ;;
            
        # 📊 Status
        status)
            yoga_daemon_status
            ;;
            
        # 🔄 Update
        update)
            _yoga_cmd_update
            ;;
            
        # 📝 Logs
        logs|log)
            _yoga_cmd_logs "$@"
            ;;
            
        # 📋 Version
        version|--version|-v)
            _yoga_cmd_version
            ;;
            
        # ❓ Help
        help|--help|-h)
            _yoga_cmd_help
            ;;
            
        # 🚫 Unknown
        *)
            yoga_fogo "❌ Comando desconhecido: $cmd"
            echo ""
            _yoga_cmd_help
            return 1
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════
# 🎯 COMMAND IMPLEMENTATIONS
# ═══════════════════════════════════════════════════════════

function _yoga_cmd_cc {
    # 🦜 Lôro Barizon: Usa standalone (não precisa de ~/.zsh/)
    yoga_section "🎯 Command Center"
    yoga_agua "💫 Iniciando interface nativa..."
    
    # 🎯 Executa CC standalone
    source "${YOGA_HOME}/core/modules/cc/standalone.sh"
    cc_standalone_run "$@"
}

function _yoga_cmd_workspace {
    local action="${1:-list}"
    [[ $# -gt 0 ]] && shift
    
    # 🦜 Lôro Barizon: Usa standalone
    yoga_section "🌌 Workspace Manager"
    
    # Source standalone
    source "${YOGA_HOME}/core/modules/workspace/standalone.sh"
    
    case "$action" in
        list|ls)
            if [[ "${1:-}" == "--simple" ]]; then
                workspace_standalone_list_simple
            else
                workspace_standalone_list_interactive
            fi
            ;;
        create|new)
            local name="${1:-}"
            local path="${2:-$(pwd)}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            yoga_agua "🏗️ Criando workspace: $name"
            # Cria diretório se não existir
            [[ ! -d "$path" ]] && mkdir -p "$path"
            workspace_standalone_action_switch "$name" "$path"
            ;;
        activate|switch|use)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            local path="${CODE_DIR:-$HOME/code}/$name"
            workspace_standalone_action_switch "$name" "$path"
            ;;
        kill|rm|delete)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            workspace_standalone_action_kill "$name"
            ;;
        *)
            # Default: lista interativa
            workspace_standalone_list_interactive
            ;;
    esac
}

function _yoga_cmd_tunnel {
    # 🚇 Cloudflare Tunnel via ~/cf-tunnels/
    "${YOGA_HOME}/bin/yoga-tunnel" "$@"
}

function _yoga_cmd_ai {
    local action="${1:-ask}"
    [[ $# -gt 0 ]] && shift
    
    # 🔍 Verifica daemon
    if ! yoga_daemon_is_running; then
        yoga_fogo "👹 Daemon não está rodando!"
        return 1
    fi
    
    yoga_section "🤖 AI Assistant"
    
    case "$action" in
        ask|query)
            local question="$*"
            [[ -z "$question" ]] && { 
                yoga_prompt "❓ O que você quer saber?: "
                read -r question
            }
            [[ -z "$question" ]] && { yoga_fogo "❓ Pergunta é obrigatória!"; return 1; }
            
            yoga_loading "🤖 Consultando IA..."
            local response=$(yoga_client_ai_ask "$question")
            echo ""
            echo "$response" | jq -r '.response // "🤔 Sem resposta"'
            ;;
        context|ctx)
            yoga_agua "📝 Adicionando contexto..."
            # Implementação futura
            ;;
        *)
            yoga_error "❌ Ação desconhecida: $action"
            return 1
            ;;
    esac
}

function _yoga_cmd_plugin {
    local action="${1:-list}"
    [[ $# -gt 0 ]] && shift
    
    # 🔍 Verifica daemon
    if ! yoga_daemon_is_running; then
        yoga_fogo "👹 Daemon não está rodando!"
        return 1
    fi
    
    yoga_section "🔌 Plugin Manager"
    
    case "$action" in
        list|ls)
            yoga_agua "📋 Listando plugins..."
            local data=$(yoga_client_plugin_list)
            echo "$data" | jq -r '.plugins[] // empty' | while read -r line; do
                echo "  $line"
            done
            ;;
        install)
            local source="${1:-}"
            [[ -z "$source" ]] && { yoga_fogo "📦 Fonte é obrigatória!"; return 1; }
            yoga_agua "📦 Instalando plugin de: $source"
            # Implementação futura
            ;;
        enable)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            yoga_agua "✅ Habilitando plugin: $name"
            # Implementação futura
            ;;
        disable)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            yoga_agua "❌ Desabilitando plugin: $name"
            # Implementação futura
            ;;
        remove|uninstall)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            yoga_warning "🗑️ Removendo plugin: $name"
            # Implementação futura
            ;;
        *)
            yoga_error "❌ Ação desconhecida: $action"
            echo ""
            yoga_info "📋 Ações disponíveis:"
            echo "  📋 list      - Lista plugins"
            echo "  📦 install   - Instala plugin"
            echo "  ✅ enable    - Habilita plugin"
            echo "  ❌ disable   - Desabilita plugin"
            echo "  🗑️ remove    - Remove plugin"
            return 1
            ;;
    esac
}

function _yoga_cmd_state {
    local action="${1:-get}"
    [[ $# -gt 0 ]] && shift
    
    # 🔍 Verifica daemon
    if ! yoga_daemon_is_running; then
        yoga_fogo "👹 Daemon não está rodando!"
        return 1
    fi
    
    yoga_section "💾 State Manager"
    
    case "$action" in
        get)
            local key="${1:-}"
            [[ -z "$key" ]] && { yoga_fogo "🔑 Key é obrigatória!"; return 1; }
            local scope="${2:-global}"
            local data=$(yoga_client_state_get "$key" "$scope")
            echo "$data" | jq -r '.value // empty'
            ;;
        set)
            local key="${1:-}"
            local value="${2:-}"
            [[ -z "$key" || -z "$value" ]] && { yoga_fogo "🔑 Key e Value são obrigatórios!"; return 1; }
            local scope="${3:-global}"
            yoga_agua "💾 Salvando: $key = $value"
            yoga_client_state_set "$key" "$value" "$scope"
            ;;
        list|ls)
            local scope="${1:-global}"
            yoga_agua "📋 Listando keys (scope: $scope)..."
            # Implementação futura
            ;;
        delete|del|rm)
            local key="${1:-}"
            [[ -z "$key" ]] && { yoga_fogo "🔑 Key é obrigatória!"; return 1; }
            yoga_agua "🗑️ Removendo: $key"
            # Implementação futura
            ;;
        *)
            yoga_error "❌ Ação desconhecida: $action"
            return 1
            ;;
    esac
}

function _yoga_cmd_logs {
    local action="${1:-tail}"
    [[ $# -gt 0 ]] && shift
    
    yoga_section "📝 Logs"
    
    case "$action" in
        tail|follow|f)
            local logfile="${YOGA_HOME}/logs/yoga.jsonl"
            if [[ -f "$logfile" ]]; then
                yoga_agua "📜 Seguindo logs (Ctrl+C para sair)..."
                tail -f "$logfile" | jq -r '. | "[\(.timestamp)] [\(.level)] [\(.module)] \(.message)"'
            else
                yoga_error "❌ Arquivo de log não encontrado"
            fi
            ;;
        list|show)
            local logfile="${YOGA_HOME}/logs/yoga.jsonl"
            local lines="${1:-50}"
            if [[ -f "$logfile" ]]; then
                tail -n "$lines" "$logfile" | jq -r '. | "[\(.timestamp)] [\(.level)] [\(.module)] \(.message)"'
            else
                yoga_error "❌ Arquivo de log não encontrado"
            fi
            ;;
        *)
            yoga_error "❌ Ação desconhecida: $action"
            return 1
            ;;
    esac
}

function _yoga_cmd_update {
    yoga_section "🔄 Self Update"
    
    yoga_agua "📦 Verificando atualizações..."
    
    # 🔍 Verifica se é git repo
    if [[ -d "${YOGA_HOME}/.git" ]]; then
        cd "$YOGA_HOME"
        
        # 📝 Backup do estado atual
        local current_ref=$(git rev-parse --short HEAD)
        yoga_debug "📍 Commit atual: $current_ref"
        
        # 🔄 Fetch latest
        if git fetch origin; then
            local behind=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo 0)
            
            if [[ "$behind" -gt 0 ]]; then
                yoga_terra "📦 $behind atualizações disponíveis!"
                yoga_prompt "Deseja atualizar? [y/N]: "
                read -r confirm
                
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    # 🛑 Para daemon se estiver rodando
                    if yoga_daemon_is_running; then
                        yoga_warning "🛑 Parando daemon para atualização..."
                        yoga_daemon_stop
                    fi
                    
                    # 🔄 Pull changes
                    if git pull origin main; then
                        yoga_terra "✅ Atualizado com sucesso!"
                        yoga_sol "🔄 Reinicie o daemon: yoga daemon start"
                    else
                        yoga_fogo "❌ Falha na atualização!"
                        return 1
                    fi
                else
                    yoga_sol "❌ Atualização cancelada"
                fi
            else
                yoga_terra "✅ Você está na versão mais recente!"
            fi
        else
            yoga_fogo "❌ Falha ao verificar atualizações"
        fi
    else
        yoga_fogo "❌ Instalação não é um repositório git"
        yoga_agua "💡 Reinstale via: git clone <repo> $YOGA_HOME"
    fi
}

function _yoga_cmd_version {
    yoga_banner
    yoga_table_header "🔧 Propriedade" "📋 Valor"
    yoga_table_row "🎨 Versão" "${YOGA_VERSION}"
    yoga_table_row "🏷️ Codename" "${YOGA_EMOJI} ${YOGA_CODENAME}"
    yoga_table_row "📅 Release" "2026"
    yoga_table_row "📦 YOGA_HOME" "${YOGA_HOME/#$HOME/~}"
    echo ""
    
    # 📊 Verifica daemon
    if yoga_daemon_is_running; then
        local data=$(yoga_client_daemon_ping)
        local daemon_version=$(echo "$data" | jq -r '.version // "unknown"')
        yoga_terra "👹 Daemon: Rodando (v$daemon_version)"
    else
        yoga_error "👹 Daemon: Parado"
    fi
}

function _yoga_cmd_help {
    yoga_banner
    yoga_section "📖 Comandos Disponíveis"
    
    echo "👹 ${YOGA_COLOR_BOLD}Daemon:${YOGA_COLOR_RESET}"
    echo "  🚀 daemon start      - Inicia o daemon"
    echo "  🛑 daemon stop       - Para o daemon"
    echo "  🔄 daemon restart    - Reinicia o daemon"
    echo "  📊 daemon status     - Status do daemon"
    echo ""
    
    echo "🎯 ${YOGA_COLOR_BOLD}Command Center:${YOGA_COLOR_RESET}"
    echo "  🎯 cc               - Interface interativa (fzf)"
    echo ""
    
    echo "🌌 ${YOGA_COLOR_BOLD}Workspaces:${YOGA_COLOR_RESET}"
    echo "  📋 workspace list    - Lista workspaces"
    echo "  ➕ workspace create  - Cria workspace"
    echo "  🔄 workspace switch   - Troca workspace"
    echo "  📍 workspace current  - Mostra atual"
    echo ""
    
    echo "🤖 ${YOGA_COLOR_BOLD}AI:${YOGA_COLOR_RESET}"
    echo "  ❓ ai ask <query>    - Pergunta à IA"
    echo ""
    
    echo "🔌 ${YOGA_COLOR_BOLD}Plugins:${YOGA_COLOR_RESET}"
    echo "  📋 plugin list       - Lista plugins"
    echo "  📦 plugin install    - Instala plugin"
    echo "  ✅ plugin enable     - Habilita plugin"
    echo ""
    
    echo "💾 ${YOGA_COLOR_BOLD}State:${YOGA_COLOR_RESET}"
    echo "  📖 state get <key>   - Lê valor"
    echo "  💾 state set <k> <v> - Salva valor"
    echo ""
    
    echo "📝 ${YOGA_COLOR_BOLD}Logs:${YOGA_COLOR_RESET}"
    echo "  📜 logs tail         - Acompanha logs"
    echo "  📋 logs show [n]      - Mostra últimos logs"
    echo ""
    
    echo "⚙️  ${YOGA_COLOR_BOLD}Sistema:${YOGA_COLOR_RESET}"
    echo "  🔄 update            - Atualiza yoga-files"
    echo "  📋 version           - Mostra versão"
    echo "  ❓ help              - Esta ajuda"
    echo ""
    
    yoga_sol "💡 Para mais detalhes: yoga <comando> --help"
}

# 🏁 Run
main "$@"
