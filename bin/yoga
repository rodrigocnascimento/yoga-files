#!/usr/bin/env zsh
# 🎭 bin/yoga
# @name: yoga-cli
# @desc: CLI Client for Yoga 3.0 - Main Entry Point 🧘‍♂️
# @usage: yoga <command> [args...]
# @author: Yoga 3.0 Lôro Barizon Edition 🦜

set -euo pipefail

# 🏠 Config
YOGA_HOME="${YOGA_HOME:-$HOME/.yoga}"
export YOGA_HOME

# 📦 Source dependencies
source "${YOGA_HOME}/core/utils/ui.sh"
source "${YOGA_HOME}/core/daemon/lifecycle.sh"
source "${YOGA_HOME}/core/daemon/client.sh"

# ═══════════════════════════════════════════════════════════
# 🎯 MAIN
# ═══════════════════════════════════════════════════════════

function main {
    local cmd="${1:-help}"
    [[ $# -gt 0 ]] && shift
    
    # 🎨 Banner nas operações principais
    case "$cmd" in
        daemon|cc|workspace|ai|plugin|state|update|version|sync)
            yoga_banner
            ;;
    esac
    
    # 🎯 Route commands
    case "$cmd" in
        # 👹 Daemon management
        daemon)
            yoga_daemon_command "$@"
            ;;
            
        # 🎯 Command Center
        cc)
            _yoga_cmd_cc "$@"
            ;;
            
        # 🌌 Workspaces
        workspace|ws)
            _yoga_cmd_workspace "$@"
            ;;
            
        # 🚇 Tunnel (cf-tunnels integration)
        tunnel)
            _yoga_cmd_tunnel "$@"
            ;;
            
        # 🤖 AI
        ai|ask)
            _yoga_cmd_ai "$@"
            ;;
            
        # 🔗 Sync
        sync)
            _yoga_cmd_sync "$@"
            ;;
            
        # 🔌 Plugins
        plugin|plugins)
            _yoga_cmd_plugin "$@"
            ;;
            
        # 💾 State
        state)
            _yoga_cmd_state "$@"
            ;;
            
        # 📊 Status
        status)
            yoga_daemon_status
            ;;
            
        # 🔄 Update
        update)
            _yoga_cmd_update
            ;;
            
        # 📝 Logs
        logs|log)
            _yoga_cmd_logs "$@"
            ;;
            
        # 📋 Version
        version|--version|-v)
            _yoga_cmd_version
            ;;
            
        # ❓ Help
        help|--help|-h)
            _yoga_cmd_help
            ;;
            
        # 🚫 Unknown
        *)
            yoga_fogo "❌ Comando desconhecido: $cmd"
            echo ""
            _yoga_cmd_help
            return 1
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════
# 🎯 COMMAND IMPLEMENTATIONS
# ═══════════════════════════════════════════════════════════

function _yoga_cmd_cc {
    # 🦜 Lôro Barizon: Usa standalone (não precisa de ~/.zsh/)
    yoga_section "🎯 Command Center"
    yoga_agua "💫 Iniciando interface nativa..."
    
    # 🎯 Executa CC standalone
    source "${YOGA_HOME}/core/modules/cc/standalone.sh"
    cc_standalone_run "$@"
}

function _yoga_cmd_workspace {
    local action="${1:-list}"
    [[ $# -gt 0 ]] && shift
    
    # 🦜 Lôro Barizon: Usa standalone
    yoga_section "🌌 Workspace Manager"
    
    # Source standalone
    source "${YOGA_HOME}/core/modules/workspace/standalone.sh"
    
    case "$action" in
        --help|-h)
            echo "🌌 Yoga Workspace Manager"
            echo ""
            echo "Usage: yoga workspace <command> [options]"
            echo ""
            echo "Commands:"
            echo "  list [options]     Lista workspaces (padrão: interativo)"
            echo "    --simple          Lista simples (sem fzf)"
            echo "    --open            Filtra apenas workspaces com sessão ativa"
            echo "  create <nome> [path]  Cria workspace"
            echo "  switch <nome>      Troca/cria workspace (alias: activate, use)"
            echo "  kill <nome>        Remove workspace (alias: rm, delete)"
            echo ""
            echo "Examples:"
            echo "  yoga workspace              # Lista interativa"
            echo "  yoga workspace list --simple # Lista simples"
            echo "  yoga workspace create api   # Cria workspace 'api'"
            echo "  yoga workspace switch api    # Troca para workspace 'api'"
            echo "  yoga workspace kill api      # Remove workspace 'api'"
            return 0
            ;;
        list|ls)
            local filter_open=false
            if [[ "${1:-}" == "--open" ]]; then
                filter_open=true
                shift
            fi
            if [[ "${1:-}" == "--simple" ]]; then
                workspace_standalone_list_simple "$filter_open"
            else
                workspace_standalone_list_interactive "$filter_open"
            fi
            ;;
        create|new)
            local name="${1:-}"
            local dest_path="${2:-$(pwd)}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            yoga_agua "🏗️ Criando workspace: $name"
            # Cria diretório se não existir
            [[ ! -d "$dest_path" ]] && mkdir -p "$dest_path"
            workspace_standalone_action_switch "$name" "$dest_path"
            ;;
        activate|switch|use)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            local dest_path="${CODE_DIR:-$HOME/code}/$name"
            workspace_standalone_action_switch "$name" "$dest_path"
            ;;
        kill|rm|delete)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            workspace_standalone_action_kill "$name"
            ;;
        *)
            # Default: lista interativa
            workspace_standalone_list_interactive
            ;;
    esac
}

function _yoga_cmd_tunnel {
    local action="${1:-}"
    [[ $# -gt 0 ]] && shift
    
    case "$action" in
        --help|-h)
            echo "🚇 Yoga Tunnel Wrapper"
            echo ""
            echo "Usage: yoga tunnel <command> [options]"
            echo ""
            echo "Este comando é um wrapper para ~/cf-tunnels/"
            echo "Para opções completas, rode: yoga-tunnel --help"
            echo ""
            echo "Commands:"
            echo "  list              Lista túneis"
            echo "  add               Adiciona túnel"
            echo "  hud               Dashboard TUI"
            return 0
            ;;
    esac
    
    # 🚇 Cloudflare Tunnel via ~/cf-tunnels/
    "${YOGA_HOME}/bin/yoga-tunnel" "$@"
}

function _yoga_cmd_ai {
    local action="${1:-ask}"
    [[ $# -gt 0 ]] && shift
    
    # 🔍 Verifica daemon
    if ! yoga_daemon_is_running; then
        yoga_fogo "👹 Daemon não está rodando!"
        return 1
    fi
    
    yoga_section "🤖 AI Assistant"
    
    case "$action" in
        ask|query)
            local question="$*"
            [[ -z "$question" ]] && { 
                yoga_prompt "❓ O que você quer saber?: "
                read -r question
            }
            [[ -z "$question" ]] && { yoga_fogo "❓ Pergunta é obrigatória!"; return 1; }
            
            yoga_loading "🤖 Consultando IA..."
            local response=$(yoga_client_ai_ask "$question")
            echo ""
            echo "$response" | jq -r '.response // "🤔 Sem resposta"'
            ;;
        context|ctx)
            yoga_agua "📝 Adicionando contexto..."
            # Implementação futura
            ;;
        *)
            yoga_error "❌ Ação desconhecida: $action"
            return 1
            ;;
    esac
}

function _yoga_cmd_plugin {
    local action="${1:-list}"
    [[ $# -gt 0 ]] && shift
    
    # 🔍 Verifica daemon
    if ! yoga_daemon_is_running; then
        yoga_fogo "👹 Daemon não está rodando!"
        return 1
    fi
    
    yoga_section "🔌 Plugin Manager"
    
    case "$action" in
        list|ls)
            yoga_agua "📋 Listando plugins..."
            local data=$(yoga_client_plugin_list)
            echo "$data" | jq -r '.plugins[] // empty' | while read -r line; do
                echo "  $line"
            done
            ;;
        install)
            local source="${1:-}"
            [[ -z "$source" ]] && { yoga_fogo "📦 Fonte é obrigatória!"; return 1; }
            yoga_agua "📦 Instalando plugin de: $source"
            # Implementação futura
            ;;
        enable)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            yoga_agua "✅ Habilitando plugin: $name"
            # Implementação futura
            ;;
        disable)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            yoga_agua "❌ Desabilitando plugin: $name"
            # Implementação futura
            ;;
        remove|uninstall)
            local name="${1:-}"
            [[ -z "$name" ]] && { yoga_fogo "🏷️ Nome é obrigatório!"; return 1; }
            yoga_warning "🗑️ Removendo plugin: $name"
            # Implementação futura
            ;;
        *)
            yoga_error "❌ Ação desconhecida: $action"
            echo ""
            yoga_info "📋 Ações disponíveis:"
            echo "  📋 list      - Lista plugins"
            echo "  📦 install   - Instala plugin"
            echo "  ✅ enable    - Habilita plugin"
            echo "  ❌ disable   - Desabilita plugin"
            echo "  🗑️ remove    - Remove plugin"
            return 1
            ;;
    esac
}

function _yoga_cmd_state {
    local action="${1:-get}"
    [[ $# -gt 0 ]] && shift
    
    # 🔍 Verifica daemon
    if ! yoga_daemon_is_running; then
        yoga_fogo "👹 Daemon não está rodando!"
        return 1
    fi
    
    yoga_section "💾 State Manager"
    
    case "$action" in
        get)
            local key="${1:-}"
            [[ -z "$key" ]] && { yoga_fogo "🔑 Key é obrigatória!"; return 1; }
            local scope="${2:-global}"
            local data=$(yoga_client_state_get "$key" "$scope")
            echo "$data" | jq -r '.value // empty'
            ;;
        set)
            local key="${1:-}"
            local value="${2:-}"
            [[ -z "$key" || -z "$value" ]] && { yoga_fogo "🔑 Key e Value são obrigatórios!"; return 1; }
            local scope="${3:-global}"
            yoga_agua "💾 Salvando: $key = $value"
            yoga_client_state_set "$key" "$value" "$scope"
            ;;
        list|ls)
            local scope="${1:-global}"
            yoga_agua "📋 Listando keys (scope: $scope)..."
            # Implementação futura
            ;;
        delete|del|rm)
            local key="${1:-}"
            [[ -z "$key" ]] && { yoga_fogo "🔑 Key é obrigatória!"; return 1; }
            yoga_agua "🗑️ Removendo: $key"
            # Implementação futura
            ;;
        *)
            yoga_error "❌ Ação desconhecida: $action"
            return 1
            ;;
    esac
}

function _yoga_cmd_logs {
    local action="${1:-tail}"
    [[ $# -gt 0 ]] && shift
    
    yoga_section "📝 Logs"
    
    case "$action" in
        tail|follow|f)
            local logfile="${YOGA_HOME}/logs/yoga.jsonl"
            if [[ -f "$logfile" ]]; then
                yoga_agua "📜 Seguindo logs (Ctrl+C para sair)..."
                tail -f "$logfile" | jq -r '. | "[\(.timestamp)] [\(.level)] [\(.module)] \(.message)"'
            else
                yoga_error "❌ Arquivo de log não encontrado"
            fi
            ;;
        list|show)
            local logfile="${YOGA_HOME}/logs/yoga.jsonl"
            local lines="${1:-50}"
            if [[ -f "$logfile" ]]; then
                tail -n "$lines" "$logfile" | jq -r '. | "[\(.timestamp)] [\(.level)] [\(.module)] \(.message)"'
            else
                yoga_error "❌ Arquivo de log não encontrado"
            fi
            ;;
        *)
            yoga_error "❌ Ação desconhecida: $action"
            return 1
            ;;
    esac
}

function _yoga_cmd_update {
    local action="${1:-}"
    [[ $# -gt 0 ]] && shift
    
    case "$action" in
        --help|-h)
            echo "🔄 Yoga Self Update"
            echo ""
            echo "Usage: yoga update [options]"
            echo ""
            echo "Options:"
            echo "  --check    Verifica se há atualizações (sem instalar)"
            echo ""
            echo "Description:"
            echo "  Verifica se há atualizações no repositório git e aplica via git pull."
            echo "  Para o daemon automaticamente antes de atualizar."
            return 0
            ;;
    esac
    
    yoga_section "🔄 Self Update"
    
    yoga_agua "📦 Verificando atualizações..."
    
    # 🔍 Verifica se é git repo
    if [[ -d "${YOGA_HOME}/.git" ]]; then
        cd "$YOGA_HOME"
        
        # 📝 Backup do estado atual
        local current_ref=$(git rev-parse --short HEAD)
        yoga_debug "📍 Commit atual: $current_ref"
        
        # 🔄 Fetch latest
        if git fetch origin; then
            local behind=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo 0)
            
            if [[ "$behind" -gt 0 ]]; then
                yoga_terra "📦 $behind atualizações disponíveis!"
                yoga_prompt "Deseja atualizar? [y/N]: "
                read -r confirm
                
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    # 🛑 Para daemon se estiver rodando
                    if yoga_daemon_is_running; then
                        yoga_warning "🛑 Parando daemon para atualização..."
                        yoga_daemon_stop
                    fi
                    
                    # 🔄 Stash and pull, then restore stashed changes
                    yoga_agua "🔄 Atualizando..."
                    if git stash -u && git pull origin main; then
                        git stash pop 2>/dev/null || true
                        yoga_terra "✅ Atualizado com sucesso!"
                        yoga_sol "🔄 Reinicie o daemon: yoga daemon start"
                    else
                        yoga_fogo "❌ Falha na atualização!"
                        return 1
                    fi
                else
                    yoga_sol "❌ Atualização cancelada"
                fi
            else
                yoga_terra "✅ Você está na versão mais recente!"
            fi
        else
            yoga_fogo "❌ Falha ao verificar atualizações"
        fi
    else
        yoga_fogo "❌ Instalação não é um repositório git"
        yoga_agua "💡 Reinstale via: git clone <repo> $YOGA_HOME"
    fi
}

function _yoga_cmd_version {
    yoga_banner
    yoga_table_header "🔧 Propriedade" "📋 Valor"
    yoga_table_row "🎨 Versão" "${YOGA_VERSION}"
    yoga_table_row "🏷️ Codename" "${YOGA_EMOJI} ${YOGA_CODENAME}"
    yoga_table_row "📅 Release" "2026"
    yoga_table_row "📦 YOGA_HOME" "${YOGA_HOME/#$HOME/~}"
    echo ""
    
    # 📊 Verifica daemon
    if yoga_daemon_is_running; then
        local data=$(yoga_client_daemon_ping)
        local daemon_version=$(echo "$data" | jq -r '.version // "unknown"')
        yoga_terra "👹 Daemon: Rodando (v$daemon_version)"
    else
        yoga_error "👹 Daemon: Parado"
    fi
}

function _yoga_cmd_sync {
    local action="${1:-status}"
    [[ $# -gt 0 ]] && shift
    
    source "${YOGA_HOME}/core/sync/api.sh"
    
    case "$action" in
        --help|-h)
            echo "🔗 Yoga Sync"
            echo ""
            echo "Usage: yoga sync <command>"
            echo ""
            echo "Commands:"
            echo "  setup    Configure cloud sync (Firebase)"
            echo "  status   Show sync status"
            echo "  push     Force upload local data to cloud"
            echo "  pull     Force download cloud data to local"
            echo "  reset    Disconnect cloud, revert to local mode"
            echo ""
            echo "Sync Modes:"
            echo "  local    SQLite only (default, no sync)"
            echo "  cloud    Firebase sync across devices"
            echo ""
            echo "Environment:"
            echo "  YOGA_SYNC_MODE=local|cloud   Set sync mode"
            echo "  YOGA_FIREBASE_CONFIG        Path to Firebase credentials"
            echo ""
            echo "Examples:"
            echo "  yoga sync setup     # Start cloud sync setup wizard"
            echo "  yoga sync status    # Check current sync status"
            echo "  yoga sync push      # Upload data to cloud"
            echo "  yoga sync pull      # Download data from cloud"
            return 0
            ;;
        setup)
            yoga_section "🔗 Sync Setup"
            
            YOGA_SYNC_MODE="${YOGA_SYNC_MODE:-local}"
            
            if _yoga_sync_is_cloud; then
                yoga_terra "✅ Cloud sync is already configured!"
                yoga_agua "   Use 'yoga sync status' for details"
                yoga_agua "   Use 'yoga sync reset' to disconnect"
                return 0
            fi
            
            yoga_agua "🌐 Choose your sync mode:"
            echo ""
            echo "  1) Local (SQLite only, no sync across devices)"
            echo "  2) Cloud (Firebase, sync across devices)"
            echo ""
            yoga_prompt "Enter choice [1/2]: "
            read -r choice
            
            case "$choice" in
                2|cloud)
                    _yoga_sync_setup_cloud
                    ;;
                1|local|*)
                    _yoga_sync_setup_local
                    ;;
            esac
            ;;
        status)
            yoga_section "🔗 Sync Status"
            _yoga_sync_status
            ;;
        push)
            yoga_section "🔗 Sync Push"
            _yoga_sync_push
            ;;
        pull)
            yoga_section "🔗 Sync Pull"
            _yoga_sync_pull
            ;;
        reset)
            yoga_section "🔗 Sync Reset"
            _yoga_sync_reset
            ;;
        *)
            yoga_fogo "❌ Unknown sync action: $action"
            echo ""
            _yoga_cmd_sync --help
            return 1
            ;;
    esac
}

