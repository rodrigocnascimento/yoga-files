#!/usr/bin/env zsh
# 🦜 bin/yoga-tunnel
# @name: yoga-tunnel
# @desc: Wrapper para cf-tunnels com Yoga UI
# @usage: yoga tunnel [add|remove|list|start|stop|status|logs|hud]
# @version: 3.0.0
# @author: Yoga Lôro Barizon Edition
# @requires: ~/cf-tunnels/run.sh
#
# @integration:
#   - Chama ~/cf-tunnels/run.sh (tool independente do usuário)
#   - Adiciona UI Yoga (cores, emojis)
#   - Loga comandos em SQLite
#
# @examples:
#   yoga tunnel list              # Lista túneis
#   yoga tunnel add --hostname api.example.com --type http --service localhost:3000
#   yoga tunnel hud               # Dashboard TUI

YOGA_HOME="${YOGA_HOME:-$HOME/.yoga}"
source "$YOGA_HOME/core/utils/ui.sh"

CF_TUNNEL_PATH="$HOME/cf-tunnels"

# ═══════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════

# Verificar se cf-tunnels existe
if [[ ! -d "$CF_TUNNEL_PATH" ]]; then
    yoga_fogo "🚇 cf-tunnels não encontrado em $CF_TUNNEL_PATH"
    yoga_agua "💡 Instale:"
    echo "   git clone <repo> ~/cf-tunnels"
    echo "   cd ~/cf-tunnels && ./install.sh"
    exit 1
fi

# Verificar se run.sh existe
if [[ ! -f "$CF_TUNNEL_PATH/run.sh" ]]; then
    yoga_fogo "❌ $CF_TUNNEL_PATH/run.sh não encontrado"
    exit 1
fi

# Header
yoga_section "🚇 Cloudflare Tunnel"
yoga_agua "🚀 Executando cf-tunnel..."
echo ""

# Executar com args passados
"$CF_TUNNEL_PATH/run.sh" "$@"

# Log silencioso
local log_entry=$(jq -n \
    --arg ts "$(date -Iseconds)" \
    --arg module "tunnel" \
    --arg args "$*" \
    '{timestamp: $ts, level: "INFO", module: $module, command: "tunnel", args: $args}')

echo "$log_entry" >> "${YOGA_HOME}/logs/yoga.jsonl" 2>/dev/null || true
